# Copy to .env and fill in to switch any agent from mock -> real providers.

# --- master_orchestrator ---
ORCHESTRATOR_LLM_PROVIDER=mock          # mock | openai | anthropic
ORCHESTRATOR_LLM_MODEL=mock-model
ORCHESTRATOR_LLM_API_KEY=
ORCHESTRATOR_SUBAGENT_TIMEOUT_S=30

# --- web_agent ---
WEB_AGENT_SEARCH_PROVIDER=mock
WEB_AGENT_SEARCH_API_KEY=
WEB_AGENT_WEATHER_PROVIDER=mock
WEB_AGENT_WEATHER_API_KEY=

# --- doc_analyzer ---
DOC_ANALYZER_LLM_PROVIDER=mock
DOC_ANALYZER_LLM_API_KEY=

# --- image_analyzer ---
IMAGE_ANALYZER_VISION_PROVIDER=mock
IMAGE_ANALYZER_VISION_API_KEY=
