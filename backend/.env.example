# Gateway settings (prefix GATEWAY_). Copy to .env and adjust. No secrets committed.

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# CORS: the frontend origin(s). JSON list.
GATEWAY_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Orchestrator MCP integration.
#   mock -> in-process stub (default, no external process)
#   http -> connect to the running master_orchestrator MCP server over HTTP
GATEWAY_ORCHESTRATOR_MODE=mock
GATEWAY_ORCHESTRATOR_MCP_URL=http://127.0.0.1:8100/mcp
GATEWAY_ORCHESTRATOR_TOOL=orchestrate
GATEWAY_ORCHESTRATOR_TIMEOUT_S=30

# Persistence (scaffolded; not required on the mock chat path).
GATEWAY_DATABASE_URL=sqlite+aiosqlite:///./gateway.db
