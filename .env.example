# agent-chat — docker compose overrides. Copy to `.env` and adjust as needed.
# Every value has a safe default baked into docker-compose.yml; this file only
# exists so you can override without editing the compose file.

# --- Host port mappings ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
MCP_PORT=8100

# --- Backend <-> MCP wiring ---
# mock -> gateway uses its in-process stub (works with no mcp traffic).
# http -> gateway calls the mcp service at http://mcp:8100/mcp.
GATEWAY_ORCHESTRATOR_MODE=mock

# --- Frontend ---
# Base URL the browser uses to reach the gateway (host-visible).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- LLM provider for the orchestrator (mock ships by default) ---
ORCHESTRATOR_LLM_PROVIDER=mock
